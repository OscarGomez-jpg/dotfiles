{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "base": "#1e1e2e",
    "mantle": "#181825",
    "crust": "#11111b",
    "text": "#cdd6f4",
    "subtext0": "#a6adc8",
    "overlay0": "#6c7086",
    "surface0": "#313244",
    "surface1": "#45475a",
    "rosewater": "#f5e0dc",
    "mauve": "#cba6f7",
    "red": "#f38ba8",
    "peach": "#fab387",
    "yellow": "#f9e2af",
    "green": "#a6e3a1",
    "teal": "#94e2d5",
    "sky": "#89dceb",
    "blue": "#89b4fa",
    "lavender": "#b4befe"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:text",
          "style": "plain",
          "template": " ",
          "type": "text"
        },
        {
          "foreground": "p:blue",
          "options": {
            "folder_icon": "\ue5ff",
            "home_icon": "~",
            "style": "agnoster_short"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "p:green",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412"
          },
          "template": "<p:teal> \u2502 </>{{ .HEAD }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }}{{ if gt .Ahead 0 }} \u2B06{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} \u2B07{{ .Behind }}{{ end }}",
          "style": "plain",
          "type": "git"
        },
        {
          "foreground": "p:yellow",
          "options": {
            "display_mode": "files",
            "fetch_virtual_env": true
          },
          "style": "plain",
          "template": " \u2502 \ue235 {{ if .Venv }}{{ .Venv }}{{ else }}{{ .Full }}{{ end }}",
          "type": "python"
        },
        {
          "foreground": "p:peach",
          "options": {
            "display_mode": "files"
          },
          "style": "plain",
          "template": " \u2502 \ue718 {{ .Full }}",
          "type": "node"
        },
        {
          "foreground": "p:sky",
          "options": {
            "display_mode": "files"
          },
          "style": "plain",
          "template": " \u2502 \ue626 {{ .Full }}",
          "type": "go"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "p:rosewater",
          "style": "plain",
          "template": "\uf489 {{ .FormattedMs }}<p:mauve> \u2502 </>",
          "type": "executiontime"
        },
        {
          "foreground": "p:mauve",
          "style": "plain",
          "template": " {{ .CurrentDate | date \"15:04\" }}",
          "type": "time"
        },
        {
          "foreground": "p:teal",
          "style": "plain",
          "template": " \u2502 󱊣 {{ .Percentage }}% ",
          "type": "battery"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:text",
          "style": "plain",
          "template": "$",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Folder }}",
  "final_space": true,
  "version": 4
}
